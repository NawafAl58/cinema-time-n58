generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  favorites Movie[]
}

model Movie {
  id        String   @id
  title     String
  tmdbId    Int      @unique
  users     User[]
}